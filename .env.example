# ==============================================================================
# NAQOOS / MUSIC-PLAYER ENVIRONMENT TEMPLATE (v4.8)
# ==============================================================================
# This file defines the required infrastructure for the application.
# Copy this file to '.env' and fill in the values for local development.
# DO NOT COMMIT THE ACTUAL '.env' FILE.
# ==============================================================================

# --- 1. CORE APPLICATION (Flask & Security) ---
# Used for session signing and CSRF protection. Generate a long random string.
SECRET_KEY=<generate_a_high_entropy_random_string>

# The public-facing URL. Crucial for OAuth callbacks and internal link generation.
# Example: https://naqoos.dev
BASE_URL=<public_protocol_and_domain>

# SQLite or Database identifier used by the SQLAlchemy engine.
DB_NAME=database.db


# --- 2. TELEGRAM INTERFACE (Bot API) ---
# The unique authentication token provided by @BotFather.
BOT_TOKEN=<your_telegram_bot_api_token>

# The handle of your bot (without @) used for UI and deep-linking.
BOT_USERNAME=<your_bot_username_handle>

# Your personal numeric Telegram ID. Required for the "Admin Inspection" deep-links.
# Use @userinfobot to find your ID.
ADMIN_TELEGRAM_ID=<your_numeric_telegram_id>

# The ID of the Telegram Channel/Group used for persistent media storage.
# Note: Usually starts with -100 for private/public channels.
STORAGE_CHANNEL_ID=<telegram_channel_id_integer>


# --- 3. ACCESS CONTROL & SECURITY ---
# Hardcoded password for the web-based administrative dashboard (/admin).
ADMIN_PASSWORD=<secure_admin_panel_password>

# Mandatory channels for Force Join feature.
# Format: Comma-separated usernames (e.g., @channel1,@channel2) or IDs.
MANDATORY_CHANNELS=


# --- 4. DOCKER & CONTAINERIZATION ---
# Credentials for pushing/pulling images from Docker Hub or GHCR.
DOCKER_USERNAME=<your_registry_username>
DOCKER_PASSWORD=<your_registry_access_token_or_password>


# --- 5. INFRASTRUCTURE & DEPLOYMENT (CI/CD Reference) ---
# Static IP address of your VPS/Server.
SERVER_IP=<vps_ipv4_address>

# Remote user for SSH operations (e.g., ubuntu, root).
SERVER_USER=<vps_ssh_user>

# Password for SSH (If not using Private Key authentication).
SERVER_PASSWORD=<vps_ssh_password>

# The content of the Private Key (.pem/.key) for secure SSH handshake.
SSH_PRIVATE_KEY=<raw_private_key_content>


# --- 6. MEDIA ENGINES (YouTube/Streaming) ---
# Content of the cookies.txt file required for yt-dlp to bypass bot detection.
YT_COOKIES=<raw_netscape_formatted_cookies_content>

# Audio quality for standard users. Admin/Pro users automatically get 320kbps.
AUDIO_QUALITY=320